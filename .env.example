# LiveKit Cloud — https://cloud.livekit.io
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Privy — https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Fallback room name (only used if the lobby store is down)
NEXT_PUBLIC_ROOM_NAME=vibecheque-main

# Base Sepolia on-chain config
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_CHAIN_ID=84532

# Backend hot key used to sign settle() calls. Must be funded with a few
# Sepolia ETH. TESTNET ONLY — rotate before going to mainnet.
BACKEND_SIGNER_ADDRESS=
BACKEND_SIGNER_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=

# Filled in by scripts/deploy after `forge script Deploy` runs
NEXT_PUBLIC_VUSD_ADDRESS=
NEXT_PUBLIC_ESCROW_ADDRESS=

# --------------------------------------------------------------------
# Track uploads (Vercel deploys only — safe to leave unset for local dev,
# the app falls back to the filesystem-based ingest).
#
# BLOB_READ_WRITE_TOKEN is provisioned automatically when you connect a
# Vercel Blob store to the project.
#
# UPSTASH_REDIS_REST_URL / _TOKEN: create a database at
#   https://console.upstash.com → Redis → create, use the REST variant.
#
# WORKER_URL / WORKER_SECRET: pair with the worker/ service running on
# Railway (or anywhere you can run the Dockerfile). WORKER_SECRET must
# match the worker's env var; we use it to auth both directions.
#
# PUBLIC_APP_URL: used by the worker's callback URL. On Vercel this is
# automatically derived from VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL
# if you don't set it explicitly.
# --------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
WORKER_URL=https://your-vibecheque-worker.railway.app
WORKER_SECRET=change-me-to-a-long-random-string
PUBLIC_APP_URL=
