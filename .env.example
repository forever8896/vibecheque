# LiveKit Cloud — https://cloud.livekit.io
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Privy — https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Fallback room name (only used if the lobby store is down)
NEXT_PUBLIC_ROOM_NAME=vibecheque-main

# Base Sepolia on-chain config
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_CHAIN_ID=84532

# Backend hot key used to sign settle() calls. Must be funded with a few
# Sepolia ETH. TESTNET ONLY — rotate before going to mainnet.
BACKEND_SIGNER_ADDRESS=
BACKEND_SIGNER_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=

# Filled in by scripts/deploy after `forge script Deploy` runs
NEXT_PUBLIC_VUSD_ADDRESS=
NEXT_PUBLIC_ESCROW_ADDRESS=
